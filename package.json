{
  "name": "shopmanager",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "electron": "electron .",
    "build:web": "npx expo export -p web",
    "build:electron": "electron-builder --win --x64"
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.10",
    "@react-navigation/stack": "^7.8.5",
    "@reduxjs/toolkit": "^2.11.2",
    "bcryptjs": "^3.0.3",
    "expo": "~55.0.6",
    "expo-file-system": "~55.0.11",
    "expo-sharing": "~55.0.12",
    "expo-sqlite": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "express": "^4.18.2",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-web": "^0.21.0",
    "react-redux": "^9.2.0",
    "util": "^0.12.5",
    "xlsx": "^0.18.5"
  },
  "private": true,
  "devDependencies": {
    "babel-plugin-transform-inline-environment-variables": "^0.4.4",
    "electron": "^32.3.3",
    "electron-builder": "^26.8.1",
    "electron-serve": "^3.0.1"
  },
  "build": {
    "appId": "com.jackson.shopmanager",
    "productName": "ShopManager",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json"
    ]
  },
  "browser": {
    "electron": false,
    "fs": false,
    "path": false,
    "util": false,
    "os": false,
    "crypto": false
  }
}
